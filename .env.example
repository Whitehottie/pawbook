# === PawBook Supabase (.env) ===
# Copy to .env and fill in values from Supabase Dashboard → Project Settings → API
#
# Quick start:
#   1. Create project at https://supabase.com
#   2. SQL Editor → run supabase/schema.sql
#   3. Auth → Email → disable "Confirm email" (for local dev)
#   4. Fill in the three keys below
#   5. npm run seed:demo
#   6. npm run dev
#
# Full guide: supabase/SETUP.md

# Frontend (safe to use in React / Vercel env vars)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Seed script only (npm run seed:demo) — NEVER expose in the browser or on Vercel
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
